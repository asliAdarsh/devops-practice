# ==============================================
# Task 10: Bind Mounts - Node.js App
# ==============================================
FROM node:18-alpine

# Create app directory
WORKDIR /app

# Copy package.json and install dependencies
COPY package.json ./
RUN npm install

# Copy the app file (but bind mount will override this during dev)
COPY app.js ./

# Expose the app port
EXPOSE 3000

# Start the app with nodemon for auto-reload
CMD ["node", "app.js"]
