# Use the official Nginx Alpine image (lightweight)
FROM nginx:alpine

# Remove the default Nginx configuration
RUN rm /etc/nginx/conf.d/default.conf

# Copy our URL rewriting configuration
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Create a simple HTML file for try_files testing
RUN mkdir -p /usr/share/nginx/html/app && \
    echo '<html><body><h1>SPA App</h1><script>console.log("SPA loaded")</script></body></html>' > /usr/share/nginx/html/app/index.html

# Expose port 80 for HTTP traffic
EXPOSE 80

# Run Nginx in the foreground
CMD ["nginx", "-g", "daemon off;"]
